{
  "manifest_version": 3,
  "name": "PDocs SEI",
  "version": "0.0.12.2",
  "description": "Versão estendida para o SEI: inserção de documentos em lote via CSV, inclusão em bloco de assinatura e download de blocos em PDF.",
  "author": "ale-arc",
  "homepage_url": "https://github.com/ale-arc/PDocs_Fork",
  "icons": {
    "16": "src/icons/logo-16.png",
    "48": "src/icons/logo-48.png",
    "128": "src/icons/logo-128.png"
  },
  "content_scripts": [
    {
      "js": [
        "src/js/libs/jquery-3.6.0.min.js",
        "src/js/libs/jquery-ui.js",
        "src/js/libs/papaparse.js",
        "src/js/libs/jschardet.min.js",
        "src/js/injectors/injetor_processoGlobal.js"
      ],
      "css": [
        "src/css/libs/jquery-ui.css",
        "src/css/libs/jquery-ui.icon-font.min.css",
        "src/css/global.css"
      ],
      "all_frames": true,
      "matches": [
        "*://*.br/*controlador.php?acao=procedimento_trabalhar*"
      ]
    },
    {
      "js": [
        "src/js/libs/jquery-3.6.0.min.js",
        "src/js/libs/jquery-ui.js",
        "src/js/injectors/injetor_processoVisualizacao.js"
      ],
      "css": [
        "src/css/libs/jquery-ui.css",
        "src/css/libs/jquery-ui.icon-font.min.css",
        "src/css/visualizacao.css"
      ],
      "all_frames": true,
      "matches": [
        "*://*.br/*controlador.php?acao=arvore_visualizar*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "src/js/injectors/injetor_blocoAssinatura.js"
      ],
      "matches": [
        "*://*.br/*controlador.php?acao=rel_bloco_protocolo_listar*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/js/*",
        "src/css/*",
        "src/img/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}